{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base"
  ],
  "schedule": ["before 4am"],
  "ignoreDeps": [
    "org.taonity:artist-insight"
  ],
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "matchPackagePatterns": [
        "*"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "github-actions non-major dependencies",
      "groupSlug": "github-actions-non-major"
    },
    {
      "matchManagers": ["github-actions"],
      "matchPackagePatterns": [
        "*"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "groupName": "github-actions major dependencies",
      "groupSlug": "github-actions-major"
    },
    {
      "matchManagers": ["maven"],
      "matchPackagePatterns": [
        "*"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "maven non-major dependencies",
      "groupSlug": "maven-non-major"
    },
    {
      "matchManagers": ["maven"],
      "matchPackagePatterns": [
        "*"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "groupName": "maven major dependencies",
      "groupSlug": "maven-major"
    },
    {
      "matchManagers": ["npm"],
      "matchPackagePatterns": [
        "*"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "npm non-major dependencies",
      "groupSlug": "npm-non-major"
    },
    {
      "matchManagers": ["npm"],
      "matchPackagePatterns": [
        "*"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "groupName": "npm major dependencies",
      "groupSlug": "npm-major"
    },
    {
      "matchManagers": ["docker-compose"],
      "matchPackagePatterns": [
        "*"
      ],
      "groupName": "docker-compose dependencies",
      "groupSlug": "docker-compose-all"
    },
    {
      "packageNames": ["com.google.cloud.tools:jib-maven-plugin"],
      "allowedVersions": "3.4.2"
    },
    {
      "packageNames": ["postgres"],
      "allowedVersions": "16"
    }
  ]
}
